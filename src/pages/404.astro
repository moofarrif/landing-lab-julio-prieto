---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Página no encontrada | Julio Prieto Lab Dental">
  <main class="error-page">
    <div class="error-content">
      <h1 class="error-code gold-text">404</h1>
      <p class="error-message">Página no encontrada</p>
      <p class="error-description">La página que buscas no existe o fue movida.</p>
      <a href="/" class="btn btn-primary">Volver al Inicio</a>
    </div>
  </main>
</Layout>

<style>
  .error-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .error-content {
    text-align: center;
  }

  .error-code {
    font-family: var(--font-display);
    font-size: clamp(6rem, 15vw, 12rem);
    font-weight: 700;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .error-message {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    color: var(--color-white);
    margin-bottom: 1rem;
  }

  .error-description {
    color: var(--color-gray-400);
    font-size: 1.1rem;
    margin-bottom: 2.5rem;
  }
</style>
