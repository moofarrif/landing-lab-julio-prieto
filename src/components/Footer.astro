---
const currentYear = new Date().getFullYear();
---

<footer class="footer" role="contentinfo">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo">
          <span class="logo-text" aria-hidden="true">JP</span>
          <div>
            <span class="footer-name">Julio Prieto</span>
            <span class="footer-tagline">Laboratorio de Mecánica Dental</span>
          </div>
        </div>
        <p class="footer-desc">
          Laboratorio especializado en estética dental en Cali, Colombia.
          Detalle, experiencia y tecnología al servicio de tu sonrisa.
        </p>
      </div>

      <div class="footer-links-group">
        <h4 class="footer-heading">Navegación</h4>
        <nav class="footer-nav" aria-label="Navegación del pie de página">
          <a href="#inicio">Inicio</a>
          <a href="#nosotros">Nosotros</a>
          <a href="#servicios">Servicios</a>
          <a href="#casos">Casos</a>
          <a href="#contacto">Contacto</a>
        </nav>
      </div>

      <div class="footer-links-group">
        <h4 class="footer-heading">Contacto</h4>
        <address class="footer-contact">
          <a href="https://wa.me/573216950086" target="_blank" rel="noopener noreferrer">
            WhatsApp: 321 695 0086
          </a>
          <a href="https://www.instagram.com/md.julioprieto/" target="_blank" rel="noopener noreferrer">
            Instagram: @md.julioprieto
          </a>
          <span>Cali, Valle del Cauca, Colombia</span>
        </address>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Julio Prieto - Laboratorio de Estética Dental en Cali. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

