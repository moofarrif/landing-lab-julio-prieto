---
import CrownScene from './CrownScene';
---

<!-- Tall scroll container so animation plays out fully -->
<div class="hero-scroll-area" id="inicio">
  <section class="hero-sticky" aria-label="Inicio - Laboratorio dental Julio Prieto">
    <div class="hero-bg" aria-hidden="true">
      <div class="hero-overlay"></div>
    </div>

    <div class="container hero-grid">
      <div class="hero-content">
        <div class="hero-badge animate-on-scroll">
          <span class="badge-dot" aria-hidden="true"></span>
          Laboratorio de Mecánica Dental en Cali
        </div>

        <h1 class="hero-title animate-on-scroll">
          Creamos sonrisas<br />
          con <span class="gold-text">precisión</span> y<br />
          <span class="gold-text">arte</span>
        </h1>

        <p class="hero-description animate-on-scroll">
          Laboratorio especializado en estética dental. Carillas cerámicas, coronas en zirconio,
          diseño digital de sonrisa y prótesis sobre implantes con la más alta tecnología en Cali, Colombia.
        </p>

        <div class="hero-actions animate-on-scroll">
          <a href="https://wa.me/573216950086?text=Hola%2C%20me%20gustar%C3%ADa%20cotizar%20un%20trabajo%20dental" target="_blank" rel="noopener noreferrer" class="btn btn-primary" aria-label="Solicitar cotización por WhatsApp">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Solicitar Cotización
          </a>
          <a href="#servicios" class="btn btn-outline">
            Ver Servicios
          </a>
        </div>

      </div>

      <!-- 3D Crown Scene -->
      <div class="hero-3d" aria-hidden="true">
        <CrownScene client:visible />
      </div>
    </div>
  </section>
</div>

<style>
  /* Tall scroll area - user scrolls through this to drive the 3D animation */
  .hero-scroll-area {
    position: relative;
    height: 250vh;
  }

  /* Sticky inner section stays pinned to viewport */
  .hero-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100dvh;
    display: flex;
    align-items: center;
    overflow: visible;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 65% 50%, rgba(201,169,110,0.07) 0%, transparent 55%),
      radial-gradient(ellipse at 30% 50%, rgba(201,169,110,0.05) 0%, transparent 60%),
      linear-gradient(180deg, var(--color-bg) 0%, rgba(10,10,10,0.95) 100%);
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
    padding-top: 5rem;
    padding-bottom: 2rem;
  }

  .hero-content { position: relative; }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.2rem;
    border: 1px solid rgba(201,169,110,0.3);
    border-radius: 50px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-gold);
    margin-bottom: 1.2rem;
    animation: fadeInUp 0.8s ease forwards;
  }

  .badge-dot {
    width: 6px; height: 6px;
    background: var(--color-gold);
    border-radius: 50%;
    animation: pulse 2s ease infinite;
  }

  @keyframes pulse {
    0%,100% { opacity:1; }
    50% { opacity:0.4; }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem,5vw,4.5rem);
    font-weight: 600;
    color: var(--color-white);
    line-height: 1.15;
    margin-bottom: 1rem;
    animation: fadeInUp 0.8s ease 0.2s both;
  }

  .hero-description {
    font-size: 1.1rem;
    color: var(--color-gray-300);
    max-width: 520px;
    line-height: 1.8;
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.8s ease 0.4s both;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    animation: fadeInUp 0.8s ease 0.6s both;
  }

  /* 3D Scene */
  .hero-3d {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 550px;
    align-self: stretch;
  }

  @keyframes scrollDown {
    0%  { transform: scaleY(0); transform-origin: top; }
    50% { transform: scaleY(1); transform-origin: top; }
    51% { transform-origin: bottom; }
    100%{ transform: scaleY(0); transform-origin: bottom; }
  }

  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr;
      padding-top: 7rem;
    }
    .hero-3d { order: -1; min-height: 350px; }
  }

  @media (max-width: 768px) {
    .hero-grid { padding-top: 6rem; }
    .hero-3d { min-height: 300px; }

    .hero-stats {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
    .stat-divider { width: 40px; height: 1px; }
    .hero-actions { flex-direction: column; }
    .hero-actions .btn { width: 100%; justify-content: center; }
  }
</style>
